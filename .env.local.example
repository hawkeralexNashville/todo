# --- Site password gate ---------------------------------------------------
# The single shared password that unlocks the whole site.
# There are no user accounts; this is one gate for everyone.
SITE_PASSWORD=change-me-to-something-long

# --- Supabase -------------------------------------------------------------
# From your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The SERVICE ROLE key (secret). Server-side only. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App behavior ---------------------------------------------------------
# IANA timezone used for the 4:00 AM daily reset of evergreen items.
# Examples: America/Chicago, America/New_York, Europe/London
APP_TIMEZONE=America/Chicago
